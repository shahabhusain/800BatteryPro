generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}

model secondAppointment {
  id            Int      @id @default(autoincrement())
  phoneNumber   String   @unique  // Add back @unique
  location      String
  selectService Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@map("second_appointments")
}

enum Role {
  USER
  ADMIN
}